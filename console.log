window.sb
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single()
  .then(function (r) {
    console.log('Supabase r:', r);
    var role = (r.data && r.data.role) ? r.data.role : 'user';
    onRole(role);
  })
  .catch(function (err) {
    console.log('Supabase catch:', err);
    var role = window.currentRole || currentRole || 'user';
    onRole(role);
  });

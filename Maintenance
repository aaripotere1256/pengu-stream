<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PenguStream — Maintenance en cours</title>
  <link href="https://fonts.googleapis.com/css2?family=Righteous&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --glacier: #b8e0f7;
      --deep: #051e30;
      --ocean: #0a3d62;
      --teal: #17a589;
      --gold: #f0c040;
      --aurora1: #43e6b5;
      --aurora2: #7b68ee;
      --aurora3: #ff6fb7;
      --text-accent: #b8e0f7;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      height: 100%;
      font-family: 'Nunito', sans-serif;
      background: var(--deep);
      color: #fff;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Aurora */
    .aurora-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .aurora-bg::before, .aurora-bg::after, .aurora-bg .a3 {
      content: '';
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: .18;
    }
    .aurora-bg::before {
      width: 700px; height: 400px;
      background: var(--aurora1);
      top: -100px; left: -200px;
      animation: drift1 14s ease-in-out infinite alternate;
    }
    .aurora-bg::after {
      width: 600px; height: 350px;
      background: var(--aurora2);
      top: 50px; right: -150px;
      animation: drift2 17s ease-in-out infinite alternate;
    }
    .aurora-bg .a3 {
      width: 500px; height: 300px;
      background: var(--aurora3);
      bottom: 100px; left: 30%;
      animation: drift3 12s ease-in-out infinite alternate;
    }
    @keyframes drift1 { to { transform: translate(80px, 60px) scale(1.1); } }
    @keyframes drift2 { to { transform: translate(-60px, 80px) scale(.9); } }
    @keyframes drift3 { to { transform: translate(50px, -70px) scale(1.2); } }

    /* Stars */
    .stars { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .star {
      position: absolute;
      width: 2px; height: 2px;
      background: #fff;
      border-radius: 50%;
      animation: twinkle var(--dur, 3s) ease-in-out infinite;
    }
    @keyframes twinkle {
      0%, 100% { opacity: .1; }
      50% { opacity: .9; }
    }

    /* Flocons */
    .flake {
      position: fixed;
      top: -30px;
      font-size: 1.3rem;
      animation: snowfall linear infinite;
      opacity: .6;
      pointer-events: none;
      z-index: 1;
    }
    @keyframes snowfall {
      to { transform: translateY(110vh) rotate(360deg); opacity: 0; }
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 40px;
      background: rgba(5, 30, 48, .85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(184, 224, 247, .12);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-family: 'Righteous', cursive;
      font-size: 1.6rem;
      color: var(--text-accent);
      text-decoration: none;
    }
    .logo-penguin { font-size: 2rem; }
    .btn-discord-nav {
      background: #5865F2;
      color: #fff;
      padding: 8px 22px;
      border-radius: 50px;
      font-weight: 800;
      font-size: .9rem;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: opacity .2s, transform .2s;
    }
    .btn-discord-nav:hover { opacity: .85; transform: translateY(-1px); }

    /* MAIN */
    main {
      position: relative;
      z-index: 10;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
      text-align: center;
    }

    .maintenance-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(240, 192, 64, .15);
      border: 1.5px solid rgba(240, 192, 64, .4);
      color: var(--gold);
      font-weight: 800;
      font-size: .8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 18px;
      border-radius: 50px;
      margin-bottom: 28px;
      animation: pulse-badge 2.5s ease-in-out infinite;
    }
    @keyframes pulse-badge {
      0%, 100% { box-shadow: 0 0 0 0 rgba(240,192,64,0); }
      50% { box-shadow: 0 0 16px 4px rgba(240,192,64,.18); }
    }

    .penguin-hero {
      font-size: 6rem;
      margin-bottom: 16px;
      animation: bob 3s ease-in-out infinite;
      display: block;
      filter: drop-shadow(0 8px 32px rgba(67,230,181,.25));
    }
    @keyframes bob {
      0%, 100% { transform: translateY(0) rotate(-3deg); }
      50% { transform: translateY(-12px) rotate(3deg); }
    }

    h1 {
      font-family: 'Righteous', cursive;
      font-size: clamp(2.2rem, 6vw, 4rem);
      color: var(--text-accent);
      line-height: 1.1;
      margin-bottom: 12px;
      text-shadow: 0 2px 30px rgba(67,230,181,.3);
    }
    h1 span {
      background: linear-gradient(135deg, var(--aurora1), var(--aurora2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 1.15rem;
      color: rgba(184,224,247,.75);
      max-width: 520px;
      line-height: 1.7;
      margin-bottom: 32px;
    }

    /* Card */
    .card {
      background: rgba(10, 61, 98, .35);
      border: 1px solid rgba(184,224,247,.12);
      backdrop-filter: blur(12px);
      border-radius: 24px;
      padding: 28px 36px;
      max-width: 540px;
      width: 100%;
      margin-bottom: 36px;
    }
    .card p {
      font-size: .95rem;
      color: rgba(255,255,255,.75);
      line-height: 1.75;
      font-style: italic;
    }
    .card .signature {
      margin-top: 16px;
      font-weight: 800;
      color: var(--text-accent);
      font-style: normal;
      font-size: 1rem;
    }

    /* Loader */
    .loader-wrap {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 36px;
      color: rgba(184,224,247,.5);
      font-size: .85rem;
      font-weight: 700;
    }
    .dots span {
      display: inline-block;
      width: 8px; height: 8px;
      background: var(--aurora1);
      border-radius: 50%;
      margin: 0 3px;
      animation: bounce-dot .9s ease-in-out infinite;
    }
    .dots span:nth-child(2) { animation-delay: .15s; background: var(--aurora2); }
    .dots span:nth-child(3) { animation-delay: .3s; background: var(--aurora3); }
    @keyframes bounce-dot {
      0%, 100% { transform: translateY(0); opacity: .4; }
      50% { transform: translateY(-8px); opacity: 1; }
    }

    /* Bouton Discord */
    .btn-discord {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #5865F2;
      color: #fff;
      font-family: 'Nunito', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      padding: 14px 32px;
      border-radius: 50px;
      text-decoration: none;
      box-shadow: 0 4px 24px rgba(88,101,242,.4);
      transition: transform .2s, box-shadow .2s, opacity .2s;
    }
    .btn-discord:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(88,101,242,.55);
      opacity: .93;
    }
    .btn-discord svg { width: 22px; height: 22px; flex-shrink: 0; }

    .info-tip {
      margin-top: 18px;
      font-size: .8rem;
      color: rgba(184,224,247,.4);
    }

    @media (max-width: 600px) {
      nav { padding: 12px 18px; }
      .card { padding: 22px 20px; }
      h1 { font-size: 2rem; }
      .penguin-hero { font-size: 4.5rem; }
    }
  </style>
</head>
<body>

  <!-- Fond aurora -->
  <div class="aurora-bg"><div class="a3"></div></div>

  <!-- Étoiles -->
  <div class="stars" id="stars"></div>

  <!-- NAV -->
  <nav>
    <a class="logo" href="#">
      <span class="logo-penguin">🐧</span>
      PenguStream
    </a>
    <a class="btn-discord-nav" href="https://discord.gg/VOTRE_LIEN" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
        <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963a.074.074 0 0 0-.041-.104 13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028z"/>
      </svg>
      Discord
    </a>
  </nav>

  <!-- MAIN -->
  <main>
    <div class="maintenance-badge">🔧 &nbsp;Maintenance en cours</div>

    <span class="penguin-hero">🐧</span>

    <h1>PenguStream est<br><span>temporairement hors ligne</span></h1>

    <p class="subtitle">
      Le site reviendra très bientôt ! En attendant, suis l'avancement de la maintenance et les dernières nouvelles directement sur notre Discord. ❄️
    </p>

    <div class="loader-wrap">
      Travaux en cours
      <div class="dots">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="card">
      <p>
        Hey tout le monde 👋<br><br>
        Désolé pour la gêne occasionnée - on fait tout notre possible pour remettre PenguStream en ligne le plus vite possible.
        Des contenus ont malheureusement disparu de la base de données suite à un incident technique, et on s'active pour tout restaurer proprement.
        On vous promet que ça vaut l'attente 🐧✨<br><br>
        Merci infiniment pour votre patience et votre soutien, ça compte vraiment beaucoup.
      </p>
      <div class="signature">Aaron 🐧</div>
    </div>

    <a class="btn-discord" href="https://discord.gg/VOTRE_LIEN" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.317 4.492c-1.53-.69-3.17-1.2-4.885-1.49a.075.075 0 0 0-.079.036c-.21.369-.444.85-.608 1.23a18.566 18.566 0 0 0-5.487 0 12.36 12.36 0 0 0-.617-1.23A.077.077 0 0 0 8.562 3c-1.714.29-3.354.8-4.885 1.491a.07.07 0 0 0-.032.027C.533 9.093-.32 13.555.099 17.961a.08.08 0 0 0 .031.055 20.03 20.03 0 0 0 5.993 2.98.078.078 0 0 0 .084-.026c.462-.62.874-1.275 1.226-1.963a.074.074 0 0 0-.041-.104 13.201 13.201 0 0 1-1.872-.878.075.075 0 0 1-.008-.125c.126-.093.252-.19.372-.287a.075.075 0 0 1 .078-.01c3.927 1.764 8.18 1.764 12.061 0a.075.075 0 0 1 .079.009c.12.098.245.195.372.288a.075.075 0 0 1-.006.125c-.598.344-1.22.635-1.873.877a.075.075 0 0 0-.041.105c.36.687.772 1.341 1.225 1.962a.077.077 0 0 0 .084.028 19.963 19.963 0 0 0 6.002-2.981.076.076 0 0 0 .032-.054c.5-5.094-.838-9.52-3.549-13.442a.06.06 0 0 0-.031-.028z"/>
      </svg>
      Rejoindre le Discord
    </a>

    <p class="info-tip">Rejoins le serveur pour suivre la maintenance en temps réel 🔔</p>
  </main>

  <script>
    // Étoiles
    const starsEl = document.getElementById('stars');
    for (let i = 0; i < 80; i++) {
      const s = document.createElement('div');
      s.className = 'star';
      s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;--dur:${2+Math.random()*4}s;opacity:${Math.random()*.6};`;
      starsEl.appendChild(s);
    }

    // Flocons
    const flakes = ['❄️','🐧','⛄','❄️','❄️'];
    for (let i = 0; i < 14; i++) {
      const f = document.createElement('div');
      f.className = 'flake';
      f.textContent = flakes[Math.floor(Math.random() * flakes.length)];
      const dur = 8 + Math.random() * 12;
      f.style.cssText = `left:${Math.random()*100}%;font-size:${0.9+Math.random()*1.2}rem;animation-duration:${dur}s;animation-delay:${-Math.random()*dur}s;opacity:${0.3+Math.random()*0.4};`;
      document.body.appendChild(f);
    }
  </script>
</body>
</html>
